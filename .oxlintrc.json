{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "e2e-tests/fixtures/**/*",
    "src/__tests__/evals/fixtures/**/*"
  ],
  "categories": {
    "correctness": "warn"
  },
  "rules": {
    "eslint/no-unused-vars": "error",
    "eslint/no-empty-pattern": "off",
    "eslint/no-control-regex": "off"
  }
}
