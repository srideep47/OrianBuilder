---
const title = 'Astro App';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Built with Astro" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-gray-50 flex items-center justify-center">
    <main class="text-center space-y-6">
      <h1 class="text-4xl font-bold text-gray-900">{title}</h1>
      <p class="text-gray-500 text-lg">
        Edit <code class="bg-gray-100 px-2 py-0.5 rounded font-mono">src/pages/index.astro</code> to get started.
      </p>
      <p class="text-sm text-gray-400">Powered by Astro + Tailwind CSS</p>
    </main>
  </body>
</html>
